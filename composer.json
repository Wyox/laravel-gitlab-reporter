{
    "name": "wyox/laravel-gitlab-reporter",
    "description": "Creates Gitlab Issues when Exceptions are thrown",
    "type": "library",
    "keywords": [
        "gitlab",
        "error reporting"
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "illuminate/support": "^9|^10|^11|^12|^13",
        "m4tthumphrey/php-gitlab-api": "^12.0",
        "guzzlehttp/guzzle": "^7.2",
        "http-interop/http-factory-guzzle": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.0|^11.0|^12.0|^13.0",
        "mockery/mockery": "^1.5"
    },
    "authors": [
        {
            "name": "Ivo de Bruijn",
            "email": "ik@ivodebruijn.nl"
        }
    ],
    "autoload": {
        "psr-4": {
            "Wyox\\GitlabReport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wyox\\GitlabReport\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wyox\\GitlabReport\\ServiceProvider"
            ],
            "aliases": {
                "GitlabReport": "Wyox\\GitlabReport\\Facade"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
